{
  "name": "aura",
  "version": "0.1.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "." : {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },

  "peerDependencies": {
    "@solana/kit": "^2.0.0"
  },
  "dependencies": {
    "@solana-program/compute-budget": "^0.4.0",
    "@solana-program/system": "^0.7.0",
    "@solana-program/token": "^0.5.0"
  },

  "devDependencies": {
    "@solana/kit": "^2.3.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "nanasi",
  "license": "MIT",
  "type": "module",
  "description": "Solana Typescript Library"
}
